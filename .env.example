# --- required ---

# Absolute host path to the workspace the cockpit scans. Mounted read-only
# into the container at /workspace.
PROJECTS_ROOT_HOST=/home/you/projects

# Bearer token the MCP client must send on every request.
# Generate one with:  openssl rand -hex 32
COCKPIT_TOKEN=replace-with-a-long-random-token

# --- optional ---

# Comma-separated browser Origins the transport accepts (DNS-rebinding
# defense). Unset = loopback origins (http://127.0.0.1:*, http://localhost:*,
# http://[::1]:*). Non-browser clients (Claude Code) send no Origin and are
# always allowed. Set to an explicit empty value to reject all browser Origins.
# ALLOWED_ORIGINS=

# Comma-separated Host header values the transport accepts. Unset = loopback
# (127.0.0.1:*, localhost:*, [::1]:*). Widen this only to expose the server
# beyond loopback, and adopt the OAuth upgrade path (see README) when you do.
# ALLOWED_HOSTS=

# Where memory_search looks. Defaults to the workspace root when unset.
# MEMORY_ROOT=/workspace

# Max memory_search hits before truncation.
# MAX_SEARCH_HITS=50

# Log level: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO
